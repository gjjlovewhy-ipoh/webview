# 2. 本地代理服务器
app/src/main/java/com/iptv/tvplayer/server/LocalServer.kt

# 3. 核心流媒体解析与解密引擎
app/src/main/java/com/iptv/tvplayer/data/PlaylistParser.kt

# 4. EPG 模糊匹配调度算法
app/src/main/java/com/iptv/tvplayer/data/EpgManager.kt
